# ──────────────────────────────────────────────────────────────────────────────
# Metrics Servers API — variables de entorno
# Copia este fichero como .env y rellena los valores reales.
# NUNCA subas el .env con credenciales reales al control de versiones.
# ──────────────────────────────────────────────────────────────────────────────

# ── Debug ─────────────────────────────────────────────────────────────────────
# false en producción. true activa logs HTTP detallados, stacktraces y nivel DEBUG.
APP_DEBUG=false

# ── MariaDB ───────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=metrics_db
DB_USER=metrics_user
DB_PASSWORD=change_me

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=metrics

# ── LDAP / Active Directory ───────────────────────────────────────────────────
LDAP_URL=ldap://dc.metrics.local
LDAP_BASE_DN=cn=Users,dc=metrics,dc=local
LDAP_SVC_DN=cn=svc_metrics,cn=Users,dc=metrics,dc=local
LDAP_SVC_PW=change_me

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me
BUCKET_USERS=usuarios
BUCKET_SERVIDORES=servidores
BUCKET_SERVICIOS=servicios

# ── JWT ───────────────────────────────────────────────────────────────────────
# Genera una clave aleatoria larga, p.ej.: openssl rand -hex 32
JWT_SECRET=change_me_use_a_random_secure_key
JWT_EXPIRATION_SECONDS=28800

# ── Redis (blocklist de tokens) ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── CORS ──────────────────────────────────────────────────────────────────────
# Lista JSON de orígenes permitidos
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ── SSH Probe ─────────────────────────────────────────────────────────────────
SSH_PROBE_USER=probe_user
SSH_PROBE_PASSWORD=change_me
